<div id="mobile-bottom-cta" style="width: 480px; display: flex; flex-direction: column; align-items: center; box-sizing: border-box;">
  
  <!-- Blue Bar at the top -->
  <a href="#lead-form" style="width: 480px; height: 50px; background-color: #007BC3; display: flex; align-items: center; justify-content: center; gap: 10px; box-sizing: border-box; text-decoration: none; cursor: pointer;">
    <img src="/images/icon-qualify-white.svg" style="width: 24px; height: 24px; flex-shrink: 0;" alt="Estimate" />
    <span style="color: #ffffff; font-family: Inter, sans-serif; font-size: 14px; font-weight: 600;">
      Get My Free ADU Estimate
    </span>
  </a>

  <!-- Main Background Image -->
  <img 
    alt="Ready to Unlock Your Property Hidden Potential" 
    src="/images/Ready to Unlock Your Property Hidden Potential.webp" 
    style="width: 480px; height: 280px; object-fit: cover; border-radius: 0px; display: block;" 
  />

  <!-- Dark content block below -->
  <div style="width: 480px; background-color: #111111; padding: 35px 15px; box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 20px;">
    
    <!-- Title -->
    <h2 style="font-family: 'Playfair Display', serif; font-size: 30px; font-weight: 700; line-height: 1.25em; color: #ffffff; text-align: center; margin: 0; width: 100%;">
      Ready to Unlock Your<br>Property's Hidden Potential?
    </h2>

    <!-- Subtitle/Text -->
    <p style="font-family: Inter, sans-serif; font-size: 18px; font-weight: 400; line-height: 1.35em; color: #ffffff; text-align: center; margin: 0; width: 100%;">
      Get a free 3D design and a fixed, no-surprise quote from LA's trusted ADU experts with 100% financing and 0% interest for 18 months for qualified homeowners.
    </p>

    <!-- Button -->
    <a href="#lead-form" style="display: flex; align-items: center; justify-content: center; background-color: #007BC3; width: 100%; max-width: 450px; height: 60px; text-decoration: none; border-radius: 0px; box-sizing: border-box; padding: 0 10px; margin-top: 10px;">
      <p style="margin: 0; padding: 0; text-align: center; color: #ffffff; font-family: Inter, sans-serif; font-size: 16px; line-height: 1.2em; white-space: nowrap;">
        <span style="font-weight: 600;">Check My Property's ADU Eligibility - </span>
        <span style="font-style: italic; font-weight: 800;">It's Free</span>
      </p>
    </a>

  </div>

</div>
