<div id="mobile-adu-eligibility-cta" style="width: 480px; display: flex; flex-direction: column; align-items: center; box-sizing: border-box;">
  
  <!-- Black Bar at the top -->
  <a href="#lead-form" style="width: 480px; height: 50px; background-color: #000000; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; box-sizing: border-box; text-decoration: none; cursor: pointer;">
    <img src="/images/icon-qualify.svg" style="width: 24px; height: 24px; flex-shrink: 0;" alt="Qualify" />
    <span style="color: #ffffff; font-family: Inter, sans-serif; font-size: 14px; font-weight: 600; text-transform: none;">
      See If I Qualify for 0% Financing
    </span>
  </a>

  <!-- Main Background Image -->
  <img 
    alt="Not sure which type fits your property" 
    src="/images/Not sure which type fits your property.webp" 
    style="width: 480px; height: 280px; object-fit: cover; border-radius: 0px; display: block;" 
  />

  <!-- Dark content block below -->
  <div style="width: 480px; background-color: #111111; padding: 35px 15px; box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 25px;">
    
    <!-- Title -->
    <h2 style="font-family: 'Playfair Display', serif; font-size: 30px; font-weight: 700; line-height: 1.2em; color: #ffffff; text-align: center; margin: 0; width: 100%;">
      Not sure which type fits your property?<br>We'll tell you - for free.
    </h2>

    <!-- Button -->
    <a href="#lead-form" style="display: flex; align-items: center; justify-content: center; background-color: #007BC3; width: 100%; max-width: 450px; height: 60px; text-decoration: none; border-radius: 0px; box-sizing: border-box; padding: 0 10px;">
      <p style="margin: 0; padding: 0; text-align: center; color: #ffffff; font-family: Inter, sans-serif; font-size: 16px; line-height: 1.2em; white-space: nowrap;">
        <span style="font-weight: 600;">Check My Property's ADU Eligibility - </span>
        <span style="font-style: italic; font-weight: 800;">It's Free</span>
      </p>
    </a>

  </div>

</div>
