<div id="mobile-why-us-details" style="width: 480px; background-color: #ffffff; padding: 0 0 40px 0; box-sizing: border-box; display: flex; flex-direction: column; align-items: center;">
  
  <!-- Large Image on Top -->
  <img 
    alt="Modern ADU Kitchen" 
    src="images/Why 115+ LA Homeowners Chose MY Home Builders (1).jpg" 
    style="width: 480px; height: 280px; object-fit: cover; margin-bottom: 30px; border-radius: 0px;" 
  />

  <!-- Content Column below -->
  <div style="width: 450px; padding: 0 15px; box-sizing: border-box; display: flex; flex-direction: column; gap: 24px;">
    
    <!-- Main Section Title -->
    <h2 style="font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; line-height: 1.2em; text-align: left; margin: 0 0 5px 0;">
      <span style="color: #0071c8;">Why 115+ LA Homeowners</span><br>
      <span style="color: #111111;">Chose MY Home Builders.</span>
    </h2>

    <!-- List of Highlights -->
    
    <!-- Highlight 1 -->
    <div style="display: flex; gap: 15px; align-items: flex-start; width: 100%;">
      <img alt="Permit Experts" src="images/Permit Experts.png" style="width: 40px; height: auto; flex-shrink: 0;" />
      <div>
        <h3 style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 700; color: #0071c8; margin: 0 0 4px 0; text-align: left;">
          Permit Experts
        </h3>
        <p style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 500; line-height: 1.3em; color: #7E7E7E; margin: 0; text-align: left;">
          We navigate the notorious Los Angeles permitting process so you don't have to spend hours at City Hall. We submit the plans, handle the revisions, and secure the approvals.
        </p>
      </div>
    </div>

    <!-- Highlight 2 -->
    <div style="display: flex; gap: 15px; align-items: flex-start; width: 100%;">
      <img alt="Free 3D Design" src="images/Free 3D Design Rendering.png" style="width: 40px; height: auto; flex-shrink: 0;" />
      <div>
        <h3 style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 700; color: #0071c8; margin: 0 0 4px 0; text-align: left;">
          Free 3D Design Rendering
        </h3>
        <p style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 500; line-height: 1.3em; color: #7E7E7E; margin: 0; text-align: left;">
          See exactly what your new space will look like before you commit to anything. Make changes before construction starts, not after.
        </p>
      </div>
    </div>

    <!-- Highlight 3 -->
    <div style="display: flex; gap: 15px; align-items: flex-start; width: 100%;">
      <img alt="Speed to Completion" src="images/Speed to Completion.png" style="width: 40px; height: auto; flex-shrink: 0;" />
      <div>
        <h3 style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 700; color: #0071c8; margin: 0 0 4px 0; text-align: left;">
          Speed to Completion
        </h3>
        <p style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 500; line-height: 1.3em; color: #7E7E7E; margin: 0; text-align: left;">
          Because we handle design, permits, and construction under one roof, your ADU is finished and generating income faster than working with separate vendors.
        </p>
      </div>
    </div>

    <!-- Highlight 4 -->
    <div style="display: flex; gap: 15px; align-items: flex-start; width: 100%;">
      <img alt="Local Experience" src="images/25+ Years of Local Experience.png" style="width: 40px; height: auto; flex-shrink: 0;" />
      <div>
        <h3 style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 700; color: #0071c8; margin: 0 0 4px 0; text-align: left;">
          25+ Years of Local Experience
        </h3>
        <p style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 500; line-height: 1.3em; color: #7E7E7E; margin: 0; text-align: left;">
          We've been building in LA long enough to know every step of the process and every way it can go wrong if it's not handled right.
        </p>
      </div>
    </div>

    <!-- Highlight 5 -->
    <div style="display: flex; gap: 15px; align-items: flex-start; width: 100%;">
      <img alt="Everything Under One Roof" src="images/Everything Under One Roof.png" style="width: 40px; height: auto; flex-shrink: 0;" />
      <div>
        <h3 style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 700; color: #0071c8; margin: 0 0 4px 0; text-align: left;">
          Everything Under One Roof
        </h3>
        <p style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 500; line-height: 1.3em; color: #7E7E7E; margin: 0; text-align: left;">
          Design, permits, and construction handled by one accountable team. No juggling separate architects, permit expediters, and builders who each blame the other when something slips.
        </p>
      </div>
    </div>

  </div>
</div>
