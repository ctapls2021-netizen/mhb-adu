---
const items = [
  {
    logo: "/images/google.svg",
    rating: "5.0",
    style: "height: 32px;"
  },
  {
    logo: "/images/YELP SVG 1.svg",
    rating: "5.0",
    style: "height: 42px;"
  },
  {
    logo: "/images/houzz.svg",
    rating: "4.9",
    style: "height: 32px;"
  },
  {
    logo: "/images/facebook.svg",
    rating: "4.9",
    style: "height: 32px;"
  },
  {
    logo: "/images/buildzoom.svg",
    rating: "5.0",
    style: "height: 42px;"
  }
];

// Duplicate items for a seamless marquee loop
const marqueeItems = [...items, ...items];
---
<div id="mobile-reviews-marquee" style="width: 480px; background-color: #0071c8; padding: 25px 0; box-sizing: border-box; overflow: hidden; display: flex; position: relative;">
  
  <div class="marquee-track" style="display: flex; gap: 50px; animation: reviewMarqueeScroll 20s linear infinite; width: max-content; will-change: transform;">
    {marqueeItems.map((item) => (
      <div style="width: 140px; display: flex; flex-direction: column; align-items: center; justify-content: center; flex-shrink: 0; box-sizing: border-box;">
        <!-- Logo -->
        <div style="height: 45px; display: flex; align-items: center; justify-content: center;">
          <img 
            alt="Review Logo" 
            src={item.logo} 
            style={`${item.style} max-width: 120px; object-fit: contain; filter: brightness(0) invert(1);`} 
          />
        </div>
        
        <!-- Rating -->
        <span style="color: #ffffff; font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 500; margin-top: 10px; line-height: 1em;">
          {item.rating}
        </span>
      </div>
    ))}
  </div>

</div>

<style>
  @keyframes reviewMarqueeScroll {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Since we duplicated the items array once, sliding by exactly 50% of track width wraps seamlessly */
      transform: translateX(calc(-50% - 25px)); /* half of the gap is 25px */
    }
  }
</style>
