      </div>
      <h3 style="color: #ffffff; font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; line-height: 1.1em; margin: 0 0 6px 0;">
        We Handle All City Permits & Plans
      </h3>
      <p style="color: #F5F9FA; font-family: Inter, sans-serif; font-size: 16px; font-weight: 500; line-height: 1.1em; margin: 0;">
        No City Hall trips. No confusing zoning paperwork.
      </p>
    </div>

  </div>
</div>

<style is:global>
  @keyframes trustMarquee {
    0% { transform: translateX(0); }
    25% { transform: translateX(0); } /* Wait 3s */
    33% { transform: translateX(-480px); } /* Slide 1s */
    58% { transform: translateX(-480px); } /* Wait 3s */
    66% { transform: translateX(-960px); } /* Slide 1s */
    91% { transform: translateX(-960px); } /* Wait 3s */
    100% { transform: translateX(-1440px); } /* Slide 1s to clone, instantly loop */
  }
</style>
