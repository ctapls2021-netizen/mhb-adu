<div class="trust-slider-container" style="width: 480px; height: 160px; background-color: #0071c8; overflow: hidden; position: relative; display: flex; align-items: center; box-sizing: border-box;">
  <div class="trust-slider-track" style="display: flex; width: max-content; animation: trustMarquee 12s cubic-bezier(0.45, 0, 0.55, 1) infinite;">
    
    <!-- Slide 1 -->
    <div class="trust-slide" style="width: 480px; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; box-sizing: border-box; padding: 0 30px;">
      <!-- Permits Sprite Icon -->
      <div style="position: relative; width: 33px; height: 39px; overflow: hidden; margin-bottom: 12px; transform: scale(1.3); transform-origin: center;">
        <img alt="" class="css-uqjlij" loading="lazy" src="/index Adu_files/e19dd23152d4dbc3a2dcd35df7b94f516a48a678.png" style="position: absolute; max-width: none;" />
      </div>
      <h3 style="color: #ffffff; font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; line-height: 1.1em; margin: 0 0 6px 0;">
        We Handle All City Permits & Plans
      </h3>
      <p style="color: #F5F9FA; font-family: Inter, sans-serif; font-size: 16px; font-weight: 500; line-height: 1.1em; margin: 0;">
        No City Hall trips. No confusing zoning paperwork.
      </p>
    </div>

    <!-- Slide 2 -->
    <div class="trust-slide" style="width: 480px; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; box-sizing: border-box; padding: 0 30px;">
