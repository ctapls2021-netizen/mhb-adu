      <p style="color: #F5F9FA; font-family: Inter, sans-serif; font-size: 16px; font-weight: 500; line-height: 1.1em; margin: 0;">
        Build now, pay over time.
      </p>
    </div>

    <!-- Clone Slide 1 -->
    <div class="trust-slide" style="width: 480px; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; box-sizing: border-box; padding: 0 30px;">
      <!-- Permits Sprite Icon -->
      <div style="position: relative; width: 33px; height: 39px; overflow: hidden; margin-bottom: 12px; transform: scale(1.3); transform-origin: center;">
