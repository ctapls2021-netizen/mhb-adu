---
import '../styles/global.css';
import HeaderAndHero from '../components/HeaderAndHero.astro';
import ReviewsBanner from '../components/ReviewsBanner.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Financing from '../components/Financing.astro';
import ADUTypes from '../components/ADUTypes.astro';
import Process from '../components/Process.astro';
import TestimonialsAndFooter from '../components/TestimonialsAndFooter.astro';
---

<!DOCTYPE html>

<html lang="en">
<head>
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,600;1,800&family=Lato:ital,wght@0,400;0,700;1,400;1,700&family=Montserrat:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700;1,800;1,900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet"/>
<meta content="text/html; charset=utf-8" http-equiv="Content-Type"/><meta content="width=device-width, initial-scale=1" name="viewport"/><meta content="light dark" name="color-scheme"/><meta content="Los Angeles ADU Builders - My Home Builders" id="meta-bkauwd" name="description"/><meta content="ADU" id="meta-slk9yx" name="title"/><meta content="noindex" id="meta-yw3oin" name="robots"/><title id="title-wwfqwi">Los Angeles ADU Builders | My Home Builders</title>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  #clipper { width: 100%; max-width: 100vw; overflow: hidden; }
</style>
</head>
<body><div id="clipper"><div id="container"><div class="css-vf8mzy css-j6ldtg css-gnlgeb" data-breakpoint="true" data-breakpoint-id="node-0_4" data-height="13390" data-page-overflowx="hidden" data-width="1920"><div class="css-qk8q3m css-roiesn css-5z2uck"><HeaderAndHero /><ReviewsBanner /><WhyChooseUs /><Financing /><ADUTypes /><Process /><TestimonialsAndFooter /></div></div></div></div></body>
</html>
<script is:inline="">
  function scaleDesign() {
    var container = document.getElementById('container');
    var clipper   = document.getElementById('clipper');
    if (!container || !clipper) return;
    var baseWidth = 1920;
    var viewWidth = window.innerWidth;   /* matches 100vw */
    var scale     = viewWidth / baseWidth; /* fills viewport at any size */

    // Scale the main container
    container.style.width = baseWidth + 'px';
    container.style.zoom  = scale;

    // Clipper + body height matches the scaled content
    var scaledH = Math.ceil(container.offsetHeight * scale);
    clipper.style.height = scaledH + 'px';
    document.body.style.height = scaledH + 'px';


  }
  window.addEventListener('resize', scaleDesign);
  scaleDesign();
  window.addEventListener('load', scaleDesign);
</script>
